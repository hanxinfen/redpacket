<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧧 红包助手 Pro"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android 12+ 兼容 · 支持自定义设置"
            android:textSize="12sp"
            android:textColor="#999"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 服务状态卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 服务状态"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="12dp" />

            <!-- 通知监听 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📨 通知监听"
                    android:textSize="14sp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_notif_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检查中..."
                    android:textSize="13sp"
                    android:textColor="#999" />

                <Button
                    android:id="@+id/btn_notif_access"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="去授权"
                    android:textSize="12sp"
                    android:textColor="#FFF"
                    android:backgroundTint="#2196F3"
                    android:layout_marginStart="8dp"
                    android:minWidth="72dp" />
            </LinearLayout>

            <!-- 无障碍服务 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👆 无障碍服务"
                    android:textSize="14sp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_access_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检查中..."
                    android:textSize="13sp"
                    android:textColor="#999" />

                <Button
                    android:id="@+id/btn_access_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="去授权"
                    android:textSize="12sp"
                    android:textColor="#FFF"
                    android:backgroundTint="#FF9800"
                    android:layout_marginStart="8dp"
                    android:minWidth="72dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 统计卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@@android:color/white"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已抢到"
                    android:textSize="12sp"
                    android:textColor="#999" />

                <TextView
                    android:id="@+id/tv_grab_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个红包"
                    android:textSize="12sp"
                    android:textColor="#999" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:orientation="vertical"
                android:background="@@android:color/white"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最近记录"
                    android:textSize="12sp"
                    android:textColor="#999"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_last_grab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="暂无记录"
                    android:textSize="13sp"
                    android:textColor="#333"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 控制区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ 自动抢红包"
                android:textSize="15sp"
                android:textColor="#333"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switch_auto_grab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btn_setting"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⚙️ 设置"
                android:textSize="12sp"
                android:textColor="#FFF"
                android:backgroundTint="#9C27B0"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 日志 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:background="@@android:color/white"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 运行日志"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#666"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:id="@+id/sv_log"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#555"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
